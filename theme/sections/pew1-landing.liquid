{%- comment -%}
  PEW1 2.0 — Landing (web 2.0) as the storefront homepage.
  Faithful port of "PEW1 Landing.dc.html": fluid paint background,
  animated hero, scroll-spy nav, mural quote calculator, hoodie
  drag-to-rotate, reviews carousel — plus a live Shopify Storefront
  API layer (cart drawer + live products) when a token is set.
{%- endcomment -%}

{{ 'pew1-landing.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Barlow:wght@300;400;500;600;700&family=Pirata+One&family=Anton&display=swap" rel="stylesheet">

{%- liquid
  assign sf_token = section.settings.storefront_token | default: ''
  assign sf_version = section.settings.storefront_api_version | default: '2024-10'
  assign col_originales = section.settings.collection_originales | default: 'frontpage'
  assign personalizador = section.settings.personalizador_url | default: 'https://pew1sark.github.io/PEW1-PERSONALIZADOR/'
-%}

<script>
  window.PEW1_STOREFRONT = {
    domain: {{ shop.permanent_domain | json }},
    token: {{ sf_token | json }},
    apiVersion: {{ sf_version | json }}
  };
</script>

<div class="pew1-landing" data-pew-landing style="position:relative;width:100%;min-height:100vh;background:#05060A;">

  <!-- ============ LIQUID PAINT BACKGROUND ============ -->
  <div data-fallback-bg style="position:fixed;inset:0;z-index:0;background:radial-gradient(120% 120% at 50% 0%, #0A0F2E 0%, #070A1C 45%, #05060A 100%);background-size:180% 180%;animation:pew1drift 50s ease-in-out infinite;"></div>
  <canvas id="pew1-fluid" style="position:fixed;inset:0;z-index:1;width:100vw;height:100vh;display:block;opacity:0.92;pointer-events:none;"></canvas>
  <div style="position:fixed;inset:0;z-index:2;pointer-events:none;background:radial-gradient(110% 90% at 50% 42%, rgba(5,6,10,0) 36%, rgba(5,6,10,0.55) 100%);"></div>

  <!-- ============ CONTENT ============ -->
  <div style="position:relative;z-index:10;">

    <!-- ============ NAV ============ -->
    <nav style="position:fixed;top:16px;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:space-between;gap:16px;max-width:1240px;margin:0 auto;padding:0 clamp(16px,4vw,28px);">
      <a href="#inicio" aria-label="PEW1 inicio" style="flex:none;width:48px;height:48px;border-radius:9999px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.04);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.12);box-shadow:inset 0 1px 1px rgba(255,255,255,0.18), 0 8px 24px rgba(0,0,0,0.4);">
        <img src="{{ 'pewi-icon-white.png' | asset_url }}" alt="PEW1" style="width:24px;height:24px;object-fit:contain;opacity:0.95;">
      </a>

      <div data-desktop-nav style="display:flex;align-items:center;gap:2px;padding:7px 10px;border-radius:9999px;background:rgba(255,255,255,0.04);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.10);box-shadow:inset 0 1px 1px rgba(255,255,255,0.12), 0 8px 30px rgba(0,0,0,0.35);">
        <a data-spy-link="inicio" href="#inicio" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;letter-spacing:0.01em;color:#9A9A95;transition:color .25s, background .25s;">Inicio</a>
        <a data-spy-link="arte" href="#arte" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;color:#9A9A95;transition:color .25s, background .25s;">Arte</a>
        <a data-spy-link="streetwear" href="#streetwear" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;color:#9A9A95;transition:color .25s, background .25s;">Street Wear</a>
        <a data-spy-link="personalizar" href="#personalizar" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;color:#9A9A95;transition:color .25s, background .25s;">Personalizar</a>
        <a data-spy-link="murales" href="#murales" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;color:#9A9A95;transition:color .25s, background .25s;">Murales</a>
        <a data-spy-link="portfolio" href="#portfolio" style="padding:8px 15px;border-radius:9999px;font-size:13.5px;font-weight:500;color:#9A9A95;transition:color .25s, background .25s;">Portfolio</a>
      </div>

      <div style="flex:none;display:flex;align-items:center;gap:10px;">
        <a href="{{ routes.all_products_collection_url }}" style="display:none;align-items:center;gap:8px;padding:11px 20px;border-radius:9999px;background:#F5F4F0;color:#0A0F2E;font-size:13.5px;font-weight:600;letter-spacing:0.01em;box-shadow:0 8px 24px rgba(0,0,0,0.35);" data-shop-btn>Tienda</a>
        <a href="{{ routes.cart_url }}" data-pew-cart-open aria-label="Carrito" style="position:relative;flex:none;width:48px;height:48px;border-radius:9999px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.04);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.12);box-shadow:inset 0 1px 1px rgba(255,255,255,0.16), 0 8px 24px rgba(0,0,0,0.4);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5F4F0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
          <span class="pew-cart-count" data-pew-cart-count>0</span>
        </a>
        <button data-action="toggleMenu" aria-label="Menú" style="flex:none;width:48px;height:48px;border-radius:9999px;display:none;align-items:center;justify-content:center;background:rgba(255,255,255,0.04);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.12);cursor:pointer;color:#F5F4F0;box-shadow:inset 0 1px 1px rgba(255,255,255,0.16);" data-burger>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="3" y1="7" x2="21" y2="7"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="17" x2="21" y2="17"></line></svg>
        </button>
      </div>
    </nav>

    <!-- ============ MOBILE MENU ============ -->
    <div data-mobile-menu style="display:none;position:fixed;inset:0;z-index:49;background:rgba(5,6,10,0.6);-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);align-items:flex-start;justify-content:center;padding-top:88px;">
      <div style="width:min(92vw,420px);padding:14px;border-radius:28px;background:rgba(12,14,30,0.72);-webkit-backdrop-filter:blur(24px);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.12);box-shadow:inset 0 1px 1px rgba(255,255,255,0.14), 0 30px 80px rgba(0,0,0,0.6);display:flex;flex-direction:column;gap:4px;">
        <a href="#inicio" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Inicio</a>
        <a href="#arte" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Arte</a>
        <a href="#streetwear" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Street Wear</a>
        <a href="#personalizar" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Personalizar</a>
        <a href="#murales" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Murales</a>
        <a href="#portfolio" data-action="closeMenu" style="padding:16px 18px;border-radius:18px;font-size:20px;font-family:'Instrument Serif',serif;font-style:italic;color:#F5F4F0;">Portfolio</a>
        <a href="{{ routes.all_products_collection_url }}" data-action="closeMenu" style="margin-top:8px;text-align:center;padding:16px;border-radius:9999px;background:#FF7A00;color:#0A0F2E;font-weight:700;letter-spacing:0.02em;">Ir a la Tienda</a>
      </div>
    </div>

    <!-- ============ 1 · HERO ============ -->
    <header id="inicio" style="scroll-margin-top:90px;min-height:100vh;display:flex;flex-direction:column;justify-content:center;max-width:1180px;margin:0 auto;padding:140px clamp(20px,5vw,40px) 80px;">
      <div data-hero-badge style="align-self:flex-start;display:flex;align-items:center;gap:10px;padding:7px 7px 7px 16px;border-radius:9999px;background:rgba(255,255,255,0.04);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.12);box-shadow:inset 0 1px 1px rgba(255,255,255,0.14);font-size:13px;color:#C7C7C2;letter-spacing:0.02em;">
        <span style="padding:4px 11px;border-radius:9999px;background:#F5F4F0;color:#0A0F2E;font-weight:700;font-size:11px;letter-spacing:0.06em;">NUEVO</span>
        Arte que transforma · Hecho a pedido
      </div>

      <h1 style="margin:32px 0 0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:#F5F4F0;line-height:0.86;letter-spacing:-0.01em;font-size:clamp(2.9rem,8.6vw,7rem);max-width:14ch;">
        <span data-word style="display:inline-block;">El</span> <span data-word style="display:inline-block;">ser</span> <span data-word style="display:inline-block;">humano</span> <span data-word style="display:inline-block;">y</span> <span data-word style="display:inline-block;color:#FF7A00;">lo&nbsp;salvaje,</span> <span data-word style="display:inline-block;">una</span> <span data-word style="display:inline-block;">sola</span> <span data-word style="display:inline-block;">imagen.</span>
      </h1>

      <p data-hero-sub style="margin:30px 0 0;max-width:54ch;font-size:clamp(16px,2vw,19px);line-height:1.65;font-weight:300;color:#C7C7C2;">
        Mi obra explora la relación entre el ser humano y el mundo animal a través de composiciones que los integran en una sola imagen.
        <span style="color:#9A9A95;font-style:italic;font-family:'Instrument Serif',serif;font-size:1.15em;">— Nicolas Sark Pew1</span>
      </p>

      <div data-hero-cta style="display:flex;flex-wrap:wrap;align-items:center;gap:16px;margin-top:40px;">
        <a href="#arte" style="display:inline-flex;align-items:center;gap:12px;padding:18px 30px;border-radius:9999px;background:#FF7A00;color:#0A0F2E;font-weight:700;font-size:16.5px;letter-spacing:0.01em;box-shadow:0 16px 44px rgba(255,122,0,0.3);">Ver el trabajo<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0A0F2E" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg></a>
        <a href="#murales" style="display:inline-flex;align-items:center;gap:10px;padding:18px 28px;border-radius:9999px;background:rgba(255,255,255,0.05);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.14);color:#F5F4F0;font-weight:500;font-size:16px;">Cuéntame tu idea</a>
      </div>

      <div data-hero-stats style="display:flex;flex-wrap:wrap;gap:clamp(28px,5vw,64px);margin-top:64px;">
        <div><div style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2rem,4vw,2.8rem);color:#F5F4F0;line-height:1;">Óleo + aerosol</div><div style="margin-top:8px;font-size:13.5px;color:#9A9A95;letter-spacing:0.02em;">Técnica mixta sobre tela</div></div>
        <div><div style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2rem,4vw,2.8rem);color:#F5F4F0;line-height:1;">Hecho en Chile</div><div style="margin-top:8px;font-size:13.5px;color:#9A9A95;letter-spacing:0.02em;">Originales · prints · street wear</div></div>
        <div><div style="font-family:'Instrument Serif',serif;font-style:italic;font-size:clamp(2rem,4vw,2.8rem);color:#F5F4F0;line-height:1;">A pedido</div><div style="margin-top:8px;font-size:13.5px;color:#9A9A95;letter-spacing:0.02em;">Murales y obras por encargo</div></div>
      </div>
    </header>

    <!-- ============ 2 · OBRAS ORIGINALES (live via Storefront API) ============ -->
    <section id="arte" style="scroll-margin-top:80px;max-width:1180px;margin:0 auto;padding:clamp(70px,11vh,140px) clamp(20px,5vw,40px);">
      <div data-reveal style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:24px;margin-bottom:48px;">
        <div>
          <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:#9A9A95;"><span style="color:#FF7A00;">//</span> Piezas únicas</div>
          <h2 style="margin:16px 0 0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:#F5F4F0;line-height:0.92;font-size:clamp(2.4rem,6vw,4.6rem);">Obras originales</h2>
          <p style="margin:18px 0 0;max-width:48ch;font-size:16.5px;line-height:1.6;font-weight:300;color:#C7C7C2;">Óleo y aerosol sobre tela. Cada pieza integra el rostro humano con un animal — una sola imagen, una sola alma. Únicas, firmadas, irrepetibles.</p>
        </div>
        <a href="{{ routes.root_url }}collections/{{ col_originales }}" style="flex:none;display:inline-flex;align-items:center;gap:10px;padding:14px 22px;border-radius:9999px;background:rgba(255,255,255,0.05);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.12);color:#F5F4F0;font-weight:500;font-size:14.5px;">Ver todo<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF7A00" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg></a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px;" data-pew-collection="{{ col_originales }}" data-pew-limit="3">
        {%- comment -%} Static fallback cards — replaced by live products when the Storefront token is set. {%- endcomment -%}
        {%- assign fb_imgs = 'work-sombras.jpg,work-rugido.jpg,work-sagrado.jpg' | split: ',' -%}
        {%- assign fb_titles = 'Sombras y Vuelo,Rugido,Sagrado Prohibido' | split: ',' -%}
        {%- for i in (0..2) -%}
        <a data-reveal href="{{ routes.root_url }}collections/{{ col_originales }}" style="display:flex;flex-direction:column;border-radius:24px;overflow:hidden;background:rgba(255,255,255,0.035);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.10);box-shadow:inset 0 1px 1px rgba(255,255,255,0.12), 0 20px 50px rgba(0,0,0,0.35);">
          <div style="position:relative;aspect-ratio:4/5;overflow:hidden;">
            <img src="{{ fb_imgs[i] | asset_url }}" alt="{{ fb_titles[i] }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
            <span style="position:absolute;top:14px;left:14px;padding:6px 12px;border-radius:9999px;background:rgba(5,6,10,0.5);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.16);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#F5F4F0;">Pintura original</span>
          </div>
          <div style="padding:22px 22px 24px;">
            <h3 style="margin:0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;font-size:26px;color:#F5F4F0;line-height:1;">{{ fb_titles[i] }}</h3>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:18px;">
              <span style="font-size:18px;font-weight:600;color:#F5F4F0;letter-spacing:0.01em;">$1.200.000</span>
              <span style="display:inline-flex;align-items:center;gap:7px;font-size:13.5px;font-weight:500;color:#FF7A00;">Ver obra<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg></span>
            </div>
          </div>
        </a>
        {%- endfor -%}
      </div>
    </section>

    <!-- ============ 3 · FINE ART PRINT ============ -->
    <section style="max-width:1180px;margin:0 auto;padding:clamp(40px,7vh,90px) clamp(20px,5vw,40px);">
      <div data-reveal style="display:grid;grid-template-columns:1fr;gap:28px;align-items:center;border-radius:28px;overflow:hidden;background:rgba(255,255,255,0.035);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.10);box-shadow:inset 0 1px 1px rgba(255,255,255,0.12), 0 24px 60px rgba(0,0,0,0.4);" data-split>
        <div style="position:relative;min-height:340px;overflow:hidden;" data-split-img>
          <img src="{{ 'work-life-prints.jpg' | asset_url }}" alt="Fine Art Prints PEW1" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;">
        </div>
        <div style="padding:clamp(28px,4vw,52px);" data-split-text>
          <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:#9A9A95;"><span style="color:#FF7A00;">//</span> Prints</div>
          <h2 style="margin:14px 0 0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:#F5F4F0;line-height:0.94;font-size:clamp(2.2rem,5vw,3.8rem);">Fine Art Print</h2>
          <p style="margin:18px 0 0;max-width:46ch;font-size:16.5px;line-height:1.65;font-weight:300;color:#C7C7C2;">Réplicas impresas de las obras originales de Nicolas Sark, en edición limitada. Papel de algodón, color fiel, firmadas y numeradas. La obra, a tu alcance.</p>
          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:18px;margin-top:30px;">
            <span style="font-size:24px;font-weight:600;color:#F5F4F0;">Desde $15.000</span>
            <a href="{{ routes.root_url }}collections/serie-print-01-copia" style="display:inline-flex;align-items:center;gap:10px;padding:15px 24px;border-radius:9999px;background:#FF7A00;color:#0A0F2E;font-weight:700;font-size:15px;letter-spacing:0.01em;box-shadow:0 12px 36px rgba(255,122,0,0.28);">Ver prints<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0A0F2E" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg></a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 4 · POSTERS / COLECCIONABLES ============ -->
    <section style="max-width:1180px;margin:0 auto;padding:clamp(70px,11vh,140px) clamp(20px,5vw,40px);">
      <div data-reveal style="margin-bottom:46px;">
        <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:#9A9A95;"><span style="color:#FF7A00;">//</span> Coleccionables</div>
        <h2 style="margin:16px 0 0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:#F5F4F0;line-height:0.92;font-size:clamp(2.4rem,6vw,4.6rem);">Posters, stickers &amp; objetos</h2>
        <p style="margin:18px 0 0;max-width:50ch;font-size:16.5px;line-height:1.6;font-weight:300;color:#C7C7C2;">Pedazos de la obra para llevar a todas partes. Tirajes accesibles, stickers de culto y objetos para el día a día.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px;">
        <a data-reveal href="{{ routes.root_url }}collections/poster" style="display:flex;flex-direction:column;border-radius:24px;overflow:hidden;background:rgba(255,255,255,0.035);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.10);box-shadow:inset 0 1px 1px rgba(255,255,255,0.12), 0 20px 50px rgba(0,0,0,0.35);">
          <div style="position:relative;aspect-ratio:1/1;overflow:hidden;background:#0b0c12;">
            <img src="{{ 'work-prohibido.jpg' | asset_url }}" alt="Poster PEW1" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
            <span style="position:absolute;top:14px;left:14px;padding:6px 12px;border-radius:9999px;background:rgba(5,6,10,0.5);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.16);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#F5F4F0;">Posters</span>
          </div>
          <div style="padding:22px 22px 24px;">
            <h3 style="margin:0;font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;font-size:24px;color:#F5F4F0;">Posters de obra</h3>
